SESSION_SECRET=replace-with-long-random-secret

# Generate password hashes with:
# npm run hash:password -- "YourStrongPassword"
AUTH_USERS_JSON=[{"email":"couple@example.com","name":"Couple Account","role":"COUPLE","passwordHash":"scrypt:SALT:HASH"},{"email":"photographer@example.com","name":"Photographer","role":"PHOTOGRAPHER","passwordHash":"scrypt:SALT:HASH"}]

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Required for automated Find My Photos matching
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
FIND_MY_PHOTOS_SIMILARITY=92

# Required for Vercel cron authorization header
CRON_SECRET=replace-with-long-random-secret
